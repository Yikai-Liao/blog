{
  "name": "fuwari",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "TWIKOO_D1_DATABASE_ID=${TWIKOO_D1_DATABASE_ID:-local-twikoo} PUBLIC_TWIKOO_ENV_ID=${PUBLIC_TWIKOO_ENV_ID:-http://127.0.0.1:8787} bash -c 'setsid pnpm --dir comments dev & comments_pid=$!; trap \"pnpm exec astro dev stop >/dev/null 2>&1; kill -TERM -$comments_pid 2>/dev/null\" EXIT INT TERM; pnpm exec astro dev \"$@\" || exit $?; wait $comments_pid' dev",
    "dev:site": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "github-cards": "node scripts/update-github-card-data.js",
    "build": "pnpm github-cards && astro build && node scripts/build-pagefind.js",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "tsc --noEmit --isolatedDeclarations",
    "new-post": "node scripts/new-post.js",
    "format": "biome format --write ./src",
    "lint": "biome check --write ./src",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "9.0.1",
    "@expressive-code/core": "^0.44.1",
    "@expressive-code/plugin-collapsible-sections": "^0.44.1",
    "@expressive-code/plugin-line-numbers": "^0.44.1",
    "@flowershow/remark-wiki-link": "3.3.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.86",
    "@iconify/svelte": "^4.2.0",
    "@swup/astro": "^1.8.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "7.0.6",
    "astro-expressive-code": "^0.44.1",
    "astro-icon": "^1.1.5",
    "force-graph": "1.49.6",
    "hastscript": "^9.0.1",
    "ignore": "^7.0.6",
    "katex": "^0.17.0",
    "markdown-it": "^14.3.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.1",
    "remark-directive-rehype": "^0.4.2",
    "remark-github-admonitions-to-directives": "^1.0.5",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "sanitize-html": "^2.17.6",
    "sharp": "^0.35.3",
    "stylus": "^0.64.0",
    "svelte": "^5.56.7",
    "tailwindcss": "^4.3.3",
    "twikoo": "1.7.14",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.10",
    "@biomejs/biome": "2.5.5",
    "@rollup/plugin-yaml": "^4.1.2",
    "@types/hast": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/sanitize-html": "^2.16.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.1",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.10.0"
}
