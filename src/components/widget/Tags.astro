---

import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getTagList } from "../../utils/content-utils";
import { getTagUrl } from "../../utils/url-utils";
import ButtonTag from "../control/ButtonTag.astro";
import WidgetLayout from "./WidgetLayout.astro";

const COLLAPSED_HEIGHT = "7.5rem";

interface Props {
	class?: string;
	id?: string;
	style?: string;
	privateContext?: boolean;
}
const className = Astro.props.class;
const id = Astro.props.id ?? "tags";
const style = Astro.props.style;
const { privateContext = false } = Astro.props;
const tags = await getTagList(privateContext);
const isCollapsed = tags.length >= 20;
---
<WidgetLayout name={i18n(I18nKey.tags)} id={id} isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT} class={className} style={style}>
    <div class="flex gap-2 flex-wrap">
        {tags.map(t => (
            <ButtonTag
	                href={getTagUrl(t.name, privateContext)}
                label={`View all posts with the ${t.name.trim()} tag`}
                data-archive-filter="tag"
                data-archive-value={t.name}
                data-no-swup
            >
                {t.name.trim()}
            </ButtonTag>
        ))}
    </div>
</WidgetLayout>
