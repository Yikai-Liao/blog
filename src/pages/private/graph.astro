---
import Graph from "@components/Graph.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getWikiGraph } from "@utils/wiki-graph";

const graph = await getWikiGraph(true);
---

<MainGridLayout title="文档关系图" description="包含私有文章的完整引用关系图。">
	<Graph graph={{ nodes: graph.nodes, edges: graph.edges }} privateContext client:only="svelte" />
</MainGridLayout>
