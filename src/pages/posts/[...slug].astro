---
import PostEntryPage from "@components/PostEntryPage.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getPostRouteSlug } from "@utils/url-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: getPostRouteSlug(entry.data.slug) },
		props: { entry },
	}));
}

const { entry } = Astro.props;
---

<PostEntryPage entry={entry} />
